<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <customProperties>
        <name>ScreenProgressIndicator</name>
        <value>{&quot;location&quot;:&quot;top&quot;,&quot;type&quot;:&quot;simple&quot;}</value>
    </customProperties>
    <environments>Default</environments>
    <interviewLabel>Template Mapping List Action {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Template Mapping List Action</label>

    <processMetadataValues>
        <name>BuilderType</name>
        <value>LightningFlowBuilder</value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>AUTO_LAYOUT_CANVAS</value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>LightningFlowBuilder</value>
    </processMetadataValues>

    <processType>Flow</processType>

    <screens>
        <name>Template_Output_Screen</name>
        <label>Template Output Screen</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>true</allowPause>

        <fields>
            <name>TemplateOutputHtmlGenerator</name>
            <extensionName>c:templateOutputHtmlGenerator</extensionName>
            <fieldType>ComponentInstance</fieldType>
            <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
            <isRequired>true</isRequired>
            <storeOutputAutomatically>true</storeOutputAutomatically>

            <styleProperties>
                <verticalAlignment>top</verticalAlignment>
                <width>12</width>
            </styleProperties>
        </fields>

        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>

    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Template_Output_Screen</targetReference>
        </connector>
    </start>

    <status>Active</status>

    <variables>
        <name>recordIds</name>
        <dataType>String</dataType>
        <isCollection>true</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
</Flow>